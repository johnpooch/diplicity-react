require 'base64'

default_platform(:ios)

REPO_ROOT = File.expand_path("../../..", __dir__)
WEB_ROOT = File.expand_path("..", __dir__)
XCODEPROJ = File.join(WEB_ROOT, "ios/App/App.xcodeproj")
ANDROID_DIR = File.join(WEB_ROOT, "android")
ANDROID_KEYSTORE_FILE = File.join(REPO_ROOT, "diplicity-android-upload.keystore")

platform :ios do
  before_all do
    if is_ci
      setup_ci
    end
  end

  desc "Load the App Store Connect API key from env (CI) or local file (dev)"
  lane :load_api_key do
    if ENV["ASC_KEY_CONTENT"]
      app_store_connect_api_key(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key_content: ENV.fetch("ASC_KEY_CONTENT"),
        is_key_content_base64: true,
      )
    else
      key_path = File.join(REPO_ROOT, "AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8")
      unless File.exist?(key_path)
        UI.user_error!("No API key found. Set ASC_KEY_CONTENT for CI or place the .p8 file in the repo root.")
      end
      app_store_connect_api_key(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key_filepath: key_path,
      )
    end
  end

  desc "Sync certificates and profiles via match"
  lane :sync_signing do
    match(
      type: "appstore",
      readonly: is_ci,
    )
  end

  desc "Force regenerate provisioning profiles (run after adding entitlements)"
  lane :regenerate_profiles do
    load_api_key
    match(
      type: "appstore",
      force: true,
    )
  end

  desc "Set manual signing on the App target only (leaves SPM deps untouched)"
  private_lane :configure_signing do
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ,
      team_id: "G76UP8FNMS",
      profile_name: "match AppStore com.diplicity.app",
      code_sign_identity: "Apple Distribution",
      targets: ["App"],
    )
  end

  desc "Restore automatic signing for local dev"
  private_lane :restore_signing do
    update_code_signing_settings(
      use_automatic_signing: true,
      path: XCODEPROJ,
      team_id: "G76UP8FNMS",
      targets: ["App"],
    )
  end

  desc "Build and upload to TestFlight"
  lane :release do
    load_api_key
    sync_signing
    configure_signing

    begin
      version = JSON.parse(File.read(File.join(WEB_ROOT, "package.json")))["version"]
      build_number = Time.now.to_i.to_s

      build_app(
        project: XCODEPROJ,
        scheme: "App",
        output_directory: File.join(WEB_ROOT, "build"),
        output_name: "Diplicity.ipa",
        export_method: "app-store",
        xcodebuild_formatter: "",
        xcargs: [
          "MARKETING_VERSION=#{version}",
          "CURRENT_PROJECT_VERSION=#{build_number}",
        ].join(" "),
      )

      upload_to_testflight(
        skip_waiting_for_build_processing: true,
      )
    ensure
      restore_signing unless is_ci
    end
  end

  desc "Build for PR validation (no upload)"
  lane :pr_build do
    load_api_key
    sync_signing
    configure_signing

    begin
      pr_number = ENV.fetch("PR_NUMBER", "0")
      pr_title = ENV.fetch("PR_TITLE", "PR Build")
      version = JSON.parse(File.read(File.join(WEB_ROOT, "package.json")))["version"]
      build_number = Time.now.to_i.to_s

      build_app(
        project: XCODEPROJ,
        scheme: "App",
        output_directory: File.join(WEB_ROOT, "build"),
        output_name: "Diplicity-PR#{pr_number}.ipa",
        export_method: "app-store",
        xcodebuild_formatter: "",
        xcargs: [
          "MARKETING_VERSION=#{version}",
          "CURRENT_PROJECT_VERSION=#{build_number}",
        ].join(" "),
      )

      upload_to_testflight(
        skip_waiting_for_build_processing: true,
        changelog: "PR ##{pr_number}: #{pr_title}",
      )
    ensure
      restore_signing unless is_ci
    end
  end
end

platform :android do
  before_all do
    if is_ci
      setup_ci
      # Decode upload keystore from base64 secret to a file the Gradle signing
      # config can read (ANDROID_KEYSTORE_PATH env var, set below).
      File.binwrite(ANDROID_KEYSTORE_FILE, Base64.decode64(ENV.fetch("ANDROID_KEYSTORE_BASE64")))
      ENV["ANDROID_KEYSTORE_PATH"] = ANDROID_KEYSTORE_FILE
    end
  end

  private_lane :build_aab do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: ANDROID_DIR,
    )
  end

  private_lane :upload_to_play do |options|
    json_key_env = ENV["PLAY_SERVICE_ACCOUNT_JSON"]

    unless json_key_env
      UI.important("PLAY_SERVICE_ACCOUNT_JSON not set — skipping Play upload")
      next
    end

    aab_path = lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]

    # skip_upload_screenshots: true until phone screenshots are added to
    # fastlane/metadata/android/en-US/images/phoneScreenshots/
    screenshots_dir = File.join(
      __dir__, "metadata/android/en-US/images/phoneScreenshots"
    )
    has_screenshots = Dir.exist?(screenshots_dir) && !Dir.glob("#{screenshots_dir}/*.{png,jpg}").empty?

    release_status = options.fetch(:release_status, "completed")
    track = options.fetch(:track, ENV.fetch("PLAY_TRACK", "internal"))

    base_params = {
      package_name: "com.diplicityreact.app",
      aab: aab_path,
      track: track,
      release_status: release_status,
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: !has_screenshots,
    }

    # Accept either a file path (local dev) or raw JSON string (CI secret)
    if File.exist?(json_key_env.to_s)
      supply(base_params.merge(json_key: json_key_env))
    else
      supply(base_params.merge(json_key_data: json_key_env))
    end
  end

  private_lane :bump_patch_version do
    package_json_path = File.join(WEB_ROOT, "package.json")
    package = JSON.parse(File.read(package_json_path))
    major, minor, patch = package["version"].split(".").map(&:to_i)
    package["version"] = "#{major}.#{minor}.#{patch + 1}"
    File.write(package_json_path, JSON.pretty_generate(package) + "\n")
    UI.success("Bumped version to #{package["version"]}")
  end

  desc "Build signed AAB and upload to Play Console internal testing track"
  lane :release do
    build_aab
    upload_to_play
  end

  desc "Build signed AAB for PR and upload to Play Console internal testing track"
  lane :pr_build do
    pr_number = ENV.fetch("PR_NUMBER", "0")
    pr_title = ENV.fetch("PR_TITLE", "PR Build")
    UI.message("Building for PR ##{pr_number}: #{pr_title}")
    build_aab
    upload_to_play(release_status: "draft")
  end
end
