default_platform(:ios)

REPO_ROOT = File.expand_path("../../..", __dir__)
WEB_ROOT = File.expand_path("..", __dir__)

platform :ios do
  before_all do
    if is_ci
      setup_ci
    end
  end

  desc "Load the App Store Connect API key from env (CI) or local file (dev)"
  lane :load_api_key do
    if ENV["ASC_KEY_CONTENT"]
      app_store_connect_api_key(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key_content: ENV.fetch("ASC_KEY_CONTENT"),
        is_key_content_base64: true,
      )
    else
      key_path = File.join(REPO_ROOT, "AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8")
      unless File.exist?(key_path)
        UI.user_error!("No API key found. Set ASC_KEY_CONTENT for CI or place the .p8 file in the repo root.")
      end
      app_store_connect_api_key(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key_filepath: key_path,
      )
    end
  end

  desc "Sync certificates and profiles via match"
  lane :sync_signing do
    match(
      type: "appstore",
      readonly: is_ci,
    )
  end

  desc "Build and upload to TestFlight"
  lane :release do
    load_api_key
    sync_signing

    version = JSON.parse(File.read(File.join(WEB_ROOT, "package.json")))["version"]
    build_number = Time.now.to_i.to_s

    build_app(
      project: File.join(WEB_ROOT, "ios/App/App.xcodeproj"),
      scheme: "App",
      output_directory: File.join(WEB_ROOT, "build"),
      output_name: "Diplicity.ipa",
      export_method: "app-store",
      xcargs: [
        "MARKETING_VERSION=#{version}",
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=G76UP8FNMS",
      ].join(" "),
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build for PR validation (no upload)"
  lane :pr_build do
    load_api_key
    sync_signing

    pr_number = ENV.fetch("PR_NUMBER", "0")
    pr_title = ENV.fetch("PR_TITLE", "PR Build")
    version = JSON.parse(File.read(File.join(WEB_ROOT, "package.json")))["version"]
    build_number = Time.now.to_i.to_s

    build_app(
      project: File.join(WEB_ROOT, "ios/App/App.xcodeproj"),
      scheme: "App",
      output_directory: File.join(WEB_ROOT, "build"),
      output_name: "Diplicity-PR#{pr_number}.ipa",
      export_method: "app-store",
      xcargs: [
        "MARKETING_VERSION=#{version}",
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=G76UP8FNMS",
      ].join(" "),
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "PR ##{pr_number}: #{pr_title}",
    )
  end
end
