{
    "routes": [
        {
            "route": "/.well-known/apple-app-site-association",
            "headers": {
                "Content-Type": "application/json"
            }
        }
    ],
    "navigationFallback": {
        "rewrite": "index.html",
        "exclude": [
            "*.{svg,png,jpg,gif}",
            "*.{css,scss}",
            "*.js",
            "/.well-known/*"
        ]
    }
}
