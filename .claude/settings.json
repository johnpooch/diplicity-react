{
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip3:*)",
      "Bash(pwd:*)",
      "Bash(python3:*)",
      "Bash(railway:*)",
      "Bash(security:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(xcodebuild:*)",
      "Bash(xcrun:*)",
      "Read(~/.claude/*)",
      "Skill(react)",
      "mcp__XcodeBuildMCP__*",
      "mcp__mobile-mcp__*",
      "mcp__sentry__*"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(gh pr merge)",
      "Bash(gh pr close:*)",
      "Bash(gh pr close)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo delete)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo archive)",
      "Bash(gh secret:*)",
      "Bash(gh secret)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth logout)",
      "Bash(gh auth token:*)",
      "Bash(gh auth token)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f packages/web/package.json ]; then cd packages/web && npm run lint --silent 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  }
}