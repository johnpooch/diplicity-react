{
  "name": "diplicity-react",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "service",
  "runServices": ["service", "db"],
  "workspaceFolder": "/workspaces/diplicity-react",
  "containerEnv": {
    "HOME": "/tmp/inspect-ai-home",
    "XDG_DATA_HOME": "/tmp/inspect-ai-data"
  },
  "remoteEnv": {
    "HOME": "/tmp/inspect-ai-home",
    "XDG_DATA_HOME": "/tmp/inspect-ai-data"
  },
  "shutdownAction": "stopContainer",
  "forwardPorts": [8000, 5432, 5173],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.analysis.extraPaths": ["./service"],
        "python.analysis.typeCheckingMode": "basic"
      }
    }
  }
}
